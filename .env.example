# yzliste.com — Ortam Değişkenleri
# Bu dosyayı .env.local olarak kopyala ve değerleri doldur:
#   cp .env.example .env.local

# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Auth
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# AI — Anthropic (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-xxx

# AI — fal.ai (fal.ai Dashboard → Keys)
FAL_KEY=your-fal-key

# Ödeme — iyzico (merchant panel)
# Not: iyzico key'leri varsa ekle, yoksa ödeme devre dışı kalır
# IYZICO_API_KEY=your-key
# IYZICO_SECRET_KEY=your-secret

# Analytics — PostHog EU Cloud (PostHog → Project Settings)
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Rate Limiting — Upstash Redis (Upstash Console → Database)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# Bot Koruması — Cloudflare Turnstile (Cloudflare Dashboard → Turnstile)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-site-key
# TURNSTILE_SECRET_KEY=your-secret-key
